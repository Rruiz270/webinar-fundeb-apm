{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 12,13 * * *"
    },
    {
      "path": "/api/cron/send-reminders",
      "schedule": "50 19 15 5 *"
    }
  ]
}
